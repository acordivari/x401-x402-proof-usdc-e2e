# ---------------------------------------------------------------------------
# Agentic Payments Sandbox — environment template. Copy to .env and fill in.
# Everything here is TESTNET. No real funds, no real wallet.
# ---------------------------------------------------------------------------

# --- Network (Base Sepolia testnet) ---
# eip155:84532 = Base Sepolia. Public RPC works; set a key for reliability.
X402_NETWORK=eip155:84532
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# --- Facilitator (free, no API key for testnet) ---
X402_FACILITATOR_URL=https://x402.org/facilitator

# --- Merchant (mock-CVS) ---
MERCHANT_PORT=4021
# The address that receives USDC. In Phase 1 we generate/print this for you.
MERCHANT_PAY_TO=0x0000000000000000000000000000000000000000

# --- Agent wallet: Coinbase CDP Server Wallet (Phase 1) ---
# Create at https://portal.cdp.coinbase.com  (free; testnet has no cost)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# --- Identity / OIDC: Auth0 (Phase 2) ---
# Create a free tenant + Regular Web App at https://auth0.com
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_CALLBACK_URL=http://localhost:4031/callback
IDENTITY_PORT=4031

# --- Mandate signing (Phase 2) — generated locally if unset ---
MANDATE_SIGNING_KEY=
