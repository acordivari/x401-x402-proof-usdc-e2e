# ---------------------------------------------------------------------------
# Agentic Payments Sandbox — environment template. Copy to .env and fill in.
# Everything here is TESTNET. No real funds, no real wallet.
# ---------------------------------------------------------------------------

# --- Network (Base Sepolia testnet) ---
# eip155:84532 = Base Sepolia. Public RPC works; set a key for reliability.
X402_NETWORK=eip155:84532
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# --- Facilitator (free, no API key for testnet) ---
X402_FACILITATOR_URL=https://x402.org/facilitator

# --- Merchant (mock-CVS) ---
MERCHANT_PORT=4021
# The address that receives USDC. In Phase 1 we generate/print this for you.
MERCHANT_PAY_TO=0x0000000000000000000000000000000000000000

# --- Agent wallet: Coinbase CDP Server Wallet (Phase 1) ---
# Create at https://portal.cdp.coinbase.com  (free; testnet has no cost)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# --- Identity / OIDC: Auth0 (Phase 2) ---
# Create a free tenant + Regular Web App at https://auth0.com
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_CALLBACK_URL=http://localhost:4031/callback
IDENTITY_PORT=4031

# --- Mandate signing (Phase 2) — generated locally if unset ---
MANDATE_SIGNING_KEY=

# ---------------------------------------------------------------------------
# x401 + Proof verifiable credentials (Phase 5)
# ---------------------------------------------------------------------------
# PROOF_MODE=local  -> self-issued SD-JWT-VCs verified against a local trust
#                      anchor; the in-browser wallet does selective disclosure.
#                      Fully offline; used by tests/CI and the offline demo.
# PROOF_MODE=live   -> the real Proof hosted OID4VP presentation flow.
PROOF_MODE=local
DEMO_PORT=4040

# --- Wallet workflow (the demo's three selectable flows) ---
# WALLET_FLOW selects the default workflow (switchable live in the UI):
#   self-issued  -> browser-held local SD-JWT-VC, per-purchase consent (offline)
#   proof-hosted -> real Proof wallet via @proof.com/proof-vc-common, per-purchase
#   delegated    -> ONE upfront grant issues a durable, scoped mandate the agent
#                   then spends autonomously (no per-purchase human approval)
WALLET_FLOW=self-issued

# Delegated-mandate defaults: the standing budget + how long it lives.
MANDATE_BUDGET=5.00            # USDC cap for the whole mandate
MANDATE_TTL=86400             # seconds the signed mandate stays valid (24h)

# Revocation channel — how the merchant learns an Intent was revoked:
#   local -> in-process registry shared issuer<->merchant (default; offline demo)
#   http  -> the merchant reads the issuer's status endpoint over HTTP, the
#            production shape. FAIL-CLOSED: if the issuer can't be reached (or
#            doesn't answer "not revoked"), the payment is DENIED.
REVOCATION_MODE=local
REVOCATION_STATUS_TIMEOUT_MS=2000   # http mode: per-check timeout

# Spend-cap ledger — how the cumulative-cap is tracked:
#   local -> per-merchant-process, in-memory (default; resets on restart)
#   http  -> a central, file-durable ledger service the merchant reserves/commits
#            against. GLOBAL across merchants + survives restart. FAIL-CLOSED: if
#            the ledger can't be reached, the spend is DENIED.
LEDGER_MODE=local
LEDGER_FILE=                        # http mode: durable JSON file (default: $TMPDIR/agentic-payments-spend-ledger.json)

# Orchestrator session store:
#   memory -> per-process, sessions drop on restart (default)
#   file   -> durable: sessions (and any standing mandate they hold) survive a
#             restart. NOTE: continuity also needs a STABLE DEMO_SESSION_SECRET
#             (else the old signed cookies won't verify after the restart).
SESSION_STORE=memory
SESSION_FILE=                       # file mode: durable JSON (default: $TMPDIR/agentic-payments-sessions.json)

# Secret that authenticates the x401 Verifier Challenge state — and thus the
# sealed payment binding. Use any high-entropy string. A built-in dev default is
# allowed ONLY in the offline local demo; the server FAILS CLOSED (refuses to
# boot with the default) when PROOF_MODE=live or NODE_ENV=production. Set a real
# value for any shared or live deployment.
X401_ENCRYPTOR_KEY=

# --- Orchestrator web auth (F1) ---
# The demo orchestrator is single-user + state-bearing. Each browser gets an
# isolated, signed session cookie so clients can't see/spend each other's
# mandates. Access is OPEN in local dev (no token) and GATED when you set a
# token. "Exposed" posture = NODE_ENV=production or DEMO_REQUIRE_AUTH=true, in
# which case the server FAILS CLOSED: it refuses to boot without DEMO_AUTH_TOKEN
# and DEMO_SESSION_SECRET.
#   DEMO_AUTH_TOKEN    -> shared access token; POST /api/login {token} to enter.
#   DEMO_SESSION_SECRET-> signs the session cookie (random per-boot if unset locally).
#   DEMO_REQUIRE_AUTH  -> "true" forces the gate + fail-closed even off production.
DEMO_AUTH_TOKEN=
DEMO_SESSION_SECRET=
DEMO_REQUIRE_AUTH=

# --- Live Proof sandbox (PROOF_MODE=live / flow=proof-hosted) ---
# The proof-hosted + live-delegated flows drive the official @proof.com/proof-vc-common
# SDK. It maps `environment` to a base URL and pins the issuer chain to Proof's
# committed trust store (so you no longer hand-pin a CA fingerprint):
#   PROOF_ENVIRONMENT: localhost | next | staging | sandbox | production
#                      ("sandbox" => api.fairfax.proof.com)
#   PROOF_TRUST_ROOT : development (sandbox) | production
#   PROOF_RESPONSE_MODE: fragment | direct_post
PROOF_ENVIRONMENT=sandbox
PROOF_TRUST_ROOT=development
PROOF_RESPONSE_MODE=fragment
# From your Proof OAuth Application. The redirect_uri must be registered there.
# The SDK uses PROOF_CLIENT_SECRET server-side via Pushed Authorization Requests
# (PAR) — the secret never reaches the browser, and the legacy PROOF_TOKEN_ENDPOINT
# / PROOF_OAUTH_SCOPE / PROOF_API_BASE client-credentials mint is no longer needed.
PROOF_CLIENT_ID=
# Confidential-client secret. The server uses it (with PROOF_CLIENT_ID) to mint a
# client-credentials access token (OAuth: Basic id:secret -> token endpoint), then
# sends that token as a Bearer on the authorize request. Used ONLY server-side, so
# neither the secret nor the token reaches the browser. Leave blank for a public client.
PROOF_CLIENT_SECRET=
# Token endpoint; defaults to ${PROOF_API_BASE}/oauth/v2/token. Fairfax sandbox:
# https://api.fairfax.proof.com/oauth/v2/token (and set PROOF_API_BASE to match).
PROOF_TOKEN_ENDPOINT=
PROOF_OAUTH_SCOPE=
PROOF_LOGIN_HINT=                # email of your credentialed Proof sandbox user
# Must be a redirect URI registered on your OAuth app. If it is a page you don't
# control (e.g. a hosted Proof page), use the demo's "paste redirect URL"
# fallback to bring the vp_token back.
PROOF_REDIRECT_URI=http://localhost:4040/proof/callback
PROOF_API_BASE=https://api.proof.com
PROOF_SCOPE=urn:proof:params:scope:verifiable-credentials:basic
# Issuer trust. The returned credential is signed with an X.509 chain in the JWT
# x5c header; we verify the leaf signature, the chain links, and that the chain
# pins to a trusted Proof CA. By default we pin Proof's Fairfax issuing CA.
# Optionally require an exact issuer, override the pinned fingerprints (comma-
# separated SHA-256), or anchor to a root CA PEM file (recommended for prod).
# PROOF_ISSUER=https://api.fairfax.proof.com
# PROOF_TRUSTED_CA_FINGERPRINTS=FB15F049...:...   # overrides the built-in pin(s)
# PROOF_TRUSTED_CA_FILE=/path/to/proof-root-ca.pem
# transaction_data type sent to Proof: payment-mandate | session | none.
# payment-mandate:v1 makes the End-User approve the actual payment on Proof's
# screen (amount is a bare number + separate currency; payment_instrument is
# free-form). Our own payment binding (sealed into the x401 challenge) is
# enforced regardless of this setting.
PROOF_TX_DATA=payment-mandate
# PROOF_PAYMENT_INSTRUMENT_TYPE=crypto
# PROOF_PAYMENT_INSTRUMENT_ID=
# PROOF_PAYMENT_CURRENCY=USD
