{
  "name": "agentic-payments",
  "version": "0.1.0",
  "private": true,
  "description": "x402 agentic payments sandbox with human-identity authorization (HAM protocol)",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check:x401": "node scripts/check-x401-spec.mjs",
    "merchant": "tsx packages/merchant/src/server.ts",
    "agent": "tsx packages/agent/src/buyer.ts",
    "demo": "npm run build:web && npm run demo:server",
    "demo:server": "npm run server --workspace=@agentic-payments/wallet-demo",
    "demo:web": "npm run dev --workspace=@agentic-payments/wallet-demo",
    "build:web": "npm run build --workspace=@agentic-payments/wallet-demo",
    "setup:live": "tsx packages/agent/src/setup-live.ts",
    "setup:local": "tsx packages/agent/src/setup-local.ts",
    "live:discover": "tsx packages/agent/src/live/discover.ts",
    "live:buy": "tsx packages/agent/src/live/buy.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "ws": "8.21.0"
  },
  "engines": {
    "node": ">=20"
  }
}
